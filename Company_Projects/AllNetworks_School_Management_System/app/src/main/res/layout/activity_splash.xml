<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_primary">

    <!-- Pulse ring (animated via code) -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_outline"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.38" />

    <!-- Logo circle -->
    <ImageView
        android:id="@+id/logoCircle"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_school_logo"
        android:scaleX="0"
        android:scaleY="0"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/pulseRing"
        app:layout_constraintBottom_toBottomOf="@id/pulseRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WELCOME TO"
        android:textColor="#99FFFFFF"
        android:textSize="12sp"
        android:letterSpacing="0.15"
        android:alpha="0"
        android:translationY="20dp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/pulseRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAppName1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All Networks"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:alpha="0"
        android:translationY="20dp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAppName2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="School Management App"
        android:textColor="#CCFFFFFF"
        android:textSize="15sp"
        android:alpha="0"
        android:translationY="20dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:background="#55FFFFFF"
        android:alpha="0"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Empowering education, every day"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:alpha="0"
        android:translationY="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading dots -->
    <LinearLayout
        android:id="@+id/dotsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:alpha="0"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:id="@+id/dot1" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_marginEnd="6dp"
            android:background="@drawable/circle_dot" />
        <View android:id="@+id/dot2" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_marginEnd="6dp"
            android:background="@drawable/circle_dot" />
        <View android:id="@+id/dot3" android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_dot" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="#44FFFFFF"
        android:textSize="10sp"
        android:alpha="0"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


