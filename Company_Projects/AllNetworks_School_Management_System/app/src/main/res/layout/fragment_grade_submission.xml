<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.allnetworks.allnetworks_school_management_system.views.teacher.teacherAssignment.submissions.gradeSubmission.GradeSubmissionVM" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/warm_off_white"
        android:orientation="vertical"
        tools:context=".views.student.attendance.AttendanceFragment">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollIndicators="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- toolbar -->
                <LinearLayout
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:id="@+id/layout_back"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="22dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/white"
                        android:elevation="5dp"
                        android:gravity="center"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivBack"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="@{viewModel::onClick}"
                            app:srcCompat="@drawable/ic_back" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_semi_bold"
                        android:gravity="center"
                        android:text="View Assignment"
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_marginEnd="25dp"
                        android:contentDescription="Tasks"
                        android:visibility="invisible"
                        app:srcCompat="@drawable/info_2" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="12dp"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/lyperiodDetails"
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="visible"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:padding="12dp">

                                    <TextView
                                        android:id="@+id/tvAvatar"
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"
                                        android:background="@drawable/ic_oval"
                                        android:backgroundTint="@color/purple"
                                        android:fontFamily="@font/inter_semi_bold"
                                        android:gravity="center"
                                        android:text="AR"
                                        android:textColor="@color/blue_text"
                                        android:textSize="16sp" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="15dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tvName"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/inter_medium"
                                            android:text="Ahmed Raza"
                                            android:textColor="@color/text_primary"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:id="@+id/tvDateAndTime"
                                            android:layout_width="100dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="2dp"
                                            android:fontFamily="@font/inter_medium"
                                            android:singleLine="false"
                                            android:text="Submitted • 19 Apr, 3:20 PM"
                                            android:textColor="#888888"
                                            android:textSize="14sp" />
                                    </LinearLayout>

                                    <View
                                        android:layout_width="wrap_content"
                                        android:layout_height="0dp"
                                        android:layout_weight="1" />


                                    <TextView
                                        android:id="@+id/tvStatus"
                                        style="@style/TV12dpInter"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="10dp"
                                        android:background="@drawable/ic_rectangle"
                                        android:backgroundTint="@color/warm_off_white"
                                        android:paddingHorizontal="5dp"
                                        android:paddingVertical="2dp"
                                        android:text="12 Apr"
                                        android:textSize="14sp"
                                        tools:text="12 Apr" />

                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        style="@style/TV12dpInterSemiBold"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/warm_off_white"
                        android:text="@string/quick_actions"
                        android:textSize="16sp" />

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="visible"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvAvatarFile"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_marginLeft="8dp"
                                android:background="@drawable/ic_rectangle"
                                android:backgroundTint="@color/purple"
                                android:fontFamily="@font/inter_semi_bold"
                                android:gravity="center"
                                android:text="PDF"
                                android:textColor="@color/blue_text"
                                android:textSize="16sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="15dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvAssignmentName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_medium"
                                    android:text="Ahmed_ch5_answer.pdf"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvAssignmentFileSize"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/inter_medium"
                                    android:singleLine="false"
                                    android:text="184 KB • Tap to view"
                                    android:textColor="#888888"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <View
                                android:layout_width="wrap_content"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:contentDescription="@string/download_file"
                                android:src="@drawable/ic_download_file" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        style="@style/TV12dpInterSemiBold"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/warm_off_white"
                        android:text="Marks"
                        android:textSize="16sp" />

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="visible"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="15dp">

                            <HorizontalScrollView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@color/white"
                                android:scrollbars="none">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="80dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/tvTotal"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:layout_marginEnd="15dp"
                                        android:fontFamily="@font/inter_regular"
                                        android:singleLine="false"
                                        android:text="Score out of 50"
                                        android:textColor="@color/light_gray"
                                        android:textSize="14sp" />


                                    <TextView
                                        android:id="@+id/tvMinus"
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:layout_marginLeft="8dp"
                                        android:background="@drawable/ic_oval"
                                        android:backgroundTint="@color/purple"
                                        android:fontFamily="@font/inter_semi_bold"
                                        android:gravity="center"
                                        android:text="-"
                                        android:textColor="@color/blue_text"
                                        android:textSize="20sp" />

                                    <EditText
                                        android:id="@+id/tvTotalMarks"
                                        android:layout_width="70dp"
                                        android:layout_height="55dp"
                                        android:layout_marginLeft="8dp"
                                        android:background="@drawable/ic_rectangle"
                                        android:backgroundTint="@color/purple"
                                        android:fontFamily="@font/inter_regular"
                                        android:gravity="center"
                                        android:inputType="number"
                                        android:maxLength="3"
                                        android:text="42"
                                        android:textColor="@color/blue_text"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvPlus"
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:layout_marginLeft="8dp"
                                        android:background="@drawable/ic_oval"
                                        android:backgroundTint="@color/purple"
                                        android:fontFamily="@font/inter_semi_bold"
                                        android:gravity="center"
                                        android:text="+"
                                        android:textColor="@color/blue_text"
                                        android:textSize="20sp" />

                                </LinearLayout>

                            </HorizontalScrollView>


                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/totalMarksProgressbar"
                                android:layout_width="wrap_content"
                                android:layout_height="3dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="60"
                                app:trackColor="#E0E0E0" />

                            <TextView
                                android:id="@+id/tvMarksPercentage"
                                style="@style/TV12dpInter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:layout_marginTop="8dp"
                                android:backgroundTint="@color/white"
                                android:text="84%" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        style="@style/TV12dpInterSemiBold"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/warm_off_white"
                        android:text="Feedback"
                        android:textSize="16sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/MaterialTil"
                        android:layout_height="80dp"
                        android:background="@drawable/ic_rectangle_edittext"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_Feedback"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:ellipsize="end"
                            android:gravity="top|start"
                            android:hint="Add Feeback..."
                            android:inputType="text|textMultiLine"
                            android:maxLength="300"
                            android:paddingTop="8dp"
                            android:singleLine="false"
                            android:textColor="@color/textColor" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveGradesBtn"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter_medium"
                        android:onClick="@{viewModel::onClick}"
                        android:text="Save"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        app:backgroundTint="@color/app_primary"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</layout>