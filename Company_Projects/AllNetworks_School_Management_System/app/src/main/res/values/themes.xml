<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AllNetworks_School_Management_System" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.AllNetworks_School_Management_System" parent="Base.Theme.AllNetworks_School_Management_System" />

    <style name="ToolbarTitleStyle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="timeTableWeeksDaysBg" parent = "">
        <item name="android:gravity">center</item>
        <item name="fontFamily">@font/inter_bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
<!--        <item name="android:backgroundTint">#e0d1d1</item>-->
    </style>

    <!-- Tab Layout Style -->
    <style name="CustomTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabBackground">@drawable/bg_tab_selector</item>
        <item name="tabTextAppearance">@style/CustomTabTextAppearance</item>
        <item name="tabSelectedTextColor">@color/white</item>
        <item name="tabTextColor">@color/text_primary</item>
        <item name="tabIndicatorColor">@android:color/transparent</item>
        <item name="tabIndicatorHeight">0dp</item>
        <item name="tabPaddingStart">0dp</item>
        <item name="tabPaddingEnd">0dp</item>
        <item name="tabRippleColor">@android:color/transparent</item>
    </style>

    <style name="CustomTabTextAppearance" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ResultBg" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:fontFamily">@font/inter_regular</item>

    </style>



</resources>